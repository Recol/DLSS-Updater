<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>dlss-updater</id>
    <version>$version$</version>
    <title>DLSS Updater</title>
    <authors>Deco</authors>
    <projectUrl>https://github.com/Recol/DLSS-Updater</projectUrl>
    <projectSourceUrl>https://github.com/Recol/DLSS-Updater/tree/main/dlss_updater</projectSourceUrl>
    <bugTrackerUrl>https://github.com/Recol/DLSS-Updater/issues</bugTrackerUrl>
    <licenseUrl>https://github.com/Recol/DLSS-Updater/blob/main/LICENSE</licenseUrl>
    <docsUrl>https://github.com/Recol/DLSS-Updater?tab=readme-ov-file#execution-instructions</docsUrl>
    <requireLicenseAcceptance>true</requireLicenseAcceptance>
    <packageSourceUrl>https://github.com/Recol/DLSS-Updater/releases</packageSourceUrl>
    <iconUrl>https://raw.githubusercontent.com/Recol/DLSS-Updater/main/dlss_updater/icons/dlss_updater.png</iconUrl>
    <summary>A tool to update DLSS DLLs for various games and launchers.</summary>
    <description>DLSS Updater is a utility that automatically updates DLSS (Deep Learning Super Sampling) DLLs for games across multiple platforms including Steam, EA Play, Ubisoft, Epic Games, GOG, and Battle.net. It simplifies the process of keeping your games up-to-date with the latest DLSS improvements.

**Note: This application requires administrative privileges to run.**

This package installs DLSS Updater via a standard Windows MSI installer.</description>
    <releaseNotes>https://github.com/Recol/DLSS-Updater/blob/main/release_notes.txt</releaseNotes>
    <tags>dlss nvidia gaming update-tool admin</tags>
    <dependencies>
      <dependency id="chocolatey-core.extension" version="1.1.0" />
    </dependencies>
  </metadata>
  <files>
    <file src="tools\CHECKSUM" target="tools\CHECKSUM" />
    <file src="tools\chocolateyBeforeModify.ps1" target="tools" />
    <file src="tools\chocolateyInstall.ps1" target="tools" />
    <file src="tools\chocolateyUninstall.ps1" target="tools" />
    <file src="VERIFICATION.TXT" target="tools" />
    <file src="LICENSE" target="tools\LICENSE.txt" />
  </files>
</package>